# ─── Database ────────────────────────────────────
DATABASE_URL=postgresql://postgres:secret@localhost:5432/darkiq

# ─── Redis ───────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── API ─────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_ENV=development               # development | production

# ─── Frontend ────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─── Celery ──────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ─── Optional: Weather API ───────────────────────
# Open-Meteo is free and needs no key.
# Only needed if you switch to OpenWeatherMap paid tier.
# OPENWEATHER_API_KEY=<your_key_here>

# ─── Optional: Kaggle ────────────────────────────
# Required to download Instacart dataset via CLI.
# KAGGLE_USERNAME=<your_kaggle_username>
# KAGGLE_KEY=<your_kaggle_api_key>
